<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TableRow android:background="#1E1E1E" android:paddingVertical="12dp">
            <View android:layout_width="30dp" android:layout_height="0dp"/>
            <TextView android:text="COLOR" android:layout_width="0dp" android:layout_weight="3" android:textColor="#888888" android:textSize="12sp" android:textStyle="bold" android:paddingStart="8dp"/>
            <TextView android:text="DIGIT" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#888888" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:text="MULT" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#888888" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:text="TOL" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#888888" android:textSize="12sp" android:textStyle="bold"/>
        </TableRow>

        <TableRow android:id="@+id/rowBlack" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#000000"/><TextView android:text="Black" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="0" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x1" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowBrown" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#8B4513"/><TextView android:text="Brown" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="1" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x10" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±1%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowRed" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#FF0000"/><TextView android:text="Red" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="2" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x100" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±2%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowOrange" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#FFA500"/><TextView android:text="Orange" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="3" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x1k" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowYellow" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#FFFF00"/><TextView android:text="Yellow" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="4" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x10k" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowGreen" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#00FF00"/><TextView android:text="Green" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="5" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x100k" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±0.5%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowBlue" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#0000FF"/><TextView android:text="Blue" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="6" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x1M" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±0.25%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowViolet" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#EE82EE"/><TextView android:text="Violet" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="7" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x10M" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±0.1%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowGrey" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#808080"/><TextView android:text="Grey" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="8" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x100M" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±0.05%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowWhite" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#FFFFFF"/><TextView android:text="White" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="9" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x1G" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowGold" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#D4AF37"/><TextView android:text="Gold" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x0.1" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±5%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

        <TableRow android:id="@+id/rowSilver" android:paddingVertical="10dp"><View android:layout_width="30dp" android:layout_height="30dp" android:background="#C0C0C0"/><TextView android:text="Silver" android:layout_width="0dp" android:layout_weight="3" android:textColor="#FFFFFF" android:paddingStart="8dp"/><TextView android:text="-" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="x0.01" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/><TextView android:text="±10%" android:layout_width="0dp" android:layout_weight="2" android:gravity="center" android:textColor="#BBBBBB"/></TableRow>

    </TableLayout>
</ScrollView>